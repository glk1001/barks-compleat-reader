<HistoryViewButton>:
    background_normal: ''
    background_down: ''
    border: (0, 0, 0, 0)
    background_color: (0.0, 0.55, 0.0, 1) if self.state == 'down' else (0.2, 0.2, 0.2, 1)
    color: (1, 1, 1, 1)
    bold: True
    size_hint: None, 1
    width: dp(100)
    text_size: self.width, None
    halign: 'center'
    valign: 'middle'
    font_size: dp(14)

<HistoryScreen>:
    opacity: 1 if root.is_visible else 0
    size_hint: (1, 1) if root.is_visible else (0, 0)

    canvas.before:
        Color:
            rgba: 0.08, 0.08, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # Background image: a random panel from the comics in the history
    Image:
        texture: root.image_texture
        fit_mode: "cover"
        opacity: 0.35
        mipmap: True
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

    # Top action bar: view toggles on the left, clear on the right
    BoxLayout:
        orientation: 'horizontal'
        size_hint: 1, None
        height: dp(38)
        pos_hint: {'x': 0, 'top': 1}
        spacing: dp(2)
        padding: dp(2), dp(2)
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        HistoryViewButton:
            id: journal_button
            text: 'Journal'
            group: 'history_view'
            state: 'down'
            on_press: root.on_journal_pressed()

        HistoryViewButton:
            id: titles_button
            text: 'Titles'
            group: 'history_view'
            on_press: root.on_titles_pressed()

        Widget:

        Button:
            id: clear_button
            text: 'Clear History'
            size_hint: None, 1
            width: dp(120)
            background_normal: ''
            background_down: ''
            border: (0, 0, 0, 0)
            background_color: (0.45, 0.1, 0.1, 1)
            color: (1, 1, 1, 1)
            font_size: dp(14)
            on_press: root.on_clear_pressed()

    # Scrolling history rows fill the space below the action bar
    ScrollView:
        id: history_scroll
        size_hint: 1, None
        height: root.height - dp(42)
        pos_hint: {'x': 0, 'y': 0}
        do_scroll_x: False
        bar_width: dp(8)

        GridLayout:
            id: history_rows
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            padding: dp(12), dp(6)
            spacing: dp(3)
