# Helper function to create a checkbox row
<CheckBoxRow@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(20)
    spacing: dp(10)
    label_text: ""
    theme_enum: None  # property to hold the ImageThemes enum
    active: True
    CheckBox:
        size_hint_x: None
        width: dp(40)
        active: self.parent.active
        on_active:
            self.parent.active = self.active
            app._main_screen.on_checkbox_row_changed(self.parent)
    Label:
        text: self.parent.label_text
        bold: True
        text_size: self.size
        halign: 'left'
        valign: 'middle'


<BackgroundColor@Widget>
    background_color: (1, 1, 1, 1)
    sizing_factor_x: 1
    sizing_factor_y: 1
    corner_radius: 4
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            size: self.sizing_factor_x * self.size[0], self.sizing_factor_y * self.size[1]
            pos:
                self.pos[0] - (0.5 * (self.sizing_factor_x - 1) * self.size[0]), \
                self.pos[1] - (0.5 * (self.sizing_factor_y - 1) * self.size[1])
            radius: [dp(self.corner_radius)]

<BgColorLabel@Label+BackgroundColor>
    background_color: (0, 0, 0, 0)

<MenuDropDown@DropDown>:
    auto_width: False
    width: dp(100)

    Button:
        text: "Settings"
        size_hint_y: None
        height: dp(40)
        on_release: root.select("settings")

    Button:
        text: "How To"
        size_hint_y: None
        height: dp(40)
        on_release: root.select("how-to")

    Button:
        text: "About"
        size_hint_y: None
        height: dp(40)
        on_release: root.select("about")

<MainScreen>:
    pos_hint: {"center_x": 0.5, "center_y": 0.5}

    BoxLayout:
        id: main_layout
        orientation: "vertical"

        # Use a FloatLayout to layer the interactive ActionBar on top of a draggable region.
        FloatLayout:
            size_hint_y: None
            height: root.ACTION_BAR_HEIGHT

            # The shared action-bar skeleton (ui/action_bar.kv) separates the
            # clickable, draggable, and button regions; only this screen's
            # buttons are declared here.
            ReaderActionBar:
                id: action_bar
                pos_hint: {'x': 0, 'y': 0}
                size_hint: 1, 1
                icon_source: root.app_icon_filepath
                icon_clickable: True
                on_icon_release: root.goto_reader_icon_title()
                title_text: root.app_title

                BarButton:
                    id: fullscreen_button
                    text: "Fullscreen"
                    icon: str(sys_paths.get_barks_reader_fullscreen_icon_file())
                    important: True
                    on_press: root.toggle_screen_mode()

                BarButton:
                    id: go_back_button
                    text: 'Go Back'
                    icon: str(sys_paths.get_barks_reader_go_back_icon_file())
                    important: True
                    on_release: root.on_action_bar_go_back()

                BarButton:
                    id: collapse_button
                    # text: 'Collapse'
                    icon: str(sys_paths.get_barks_reader_collapse_icon_file())
                    important: True
                    on_release: root.on_action_bar_collapse()
                    opacity: 0.5 if self.disabled else 1.0

                BarButton:
                    id: change_pics_button
                    text: 'Change Pics'
                    icon: str(sys_paths.get_barks_reader_refresh_arrow_icon_file())
                    important: True
                    on_release: root.on_action_bar_change_view_images()

                BarButton:
                    id: menu_button
                    text: 'Menu'
                    icon: str(sys_paths.get_barks_reader_menu_dots_icon_file())
                    important: True
                    on_release: root.open_menu_dots(self)

                # Quit sits alone in the window corner behind the fence, so an
                # overshoot on the working buttons can't kill the app.
                QuitFence:

                BarButton:
                    id: quit_button
                    text: 'Quit'
                    icon: str(sys_paths.get_barks_reader_close_icon_file())
                    important: True
                    on_release: app.close_app()
