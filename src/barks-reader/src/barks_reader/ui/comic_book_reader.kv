<ComicBookReaderScreen>:
    pos_hint: {"center_x": 0.5, "center_y": 0.5}

    # Vertical BoxLayout reflow pattern (matches MainScreen): the action bar is a fixed-height
    # row that collapses to height 0 when hidden via hide_action_bar(). The image_layout fills
    # whatever space is left, so no padding/opacity cascade is needed.
    BoxLayout:
        id: main_layout
        orientation: "vertical"

        # Action bar row. Visibility is driven from Python via show_action_bar/hide_action_bar
        # (height + opacity + disabled). Do NOT bind opacity here.
        # The outer FloatLayout fills the row full-width so the height-collapse trick works.
        # The inner FloatLayout (action_bar_inner) is centered and sized to match the comic
        # image aspect-fit width — that's what carries the visible background and content.
        FloatLayout:
            id: action_bar
            size_hint_y: None
            height: root.ACTION_BAR_HEIGHT

            # Shared skeleton (ui/action_bar.kv). Its drag_region is what
            # scripts/read_comic.py passes to Window.set_custom_titlebar as
            # the window-drag region. The icon is not clickable here.
            ReaderActionBar:
                id: action_bar_inner
                pos_hint: {'center_x': 0.5, 'top': 1}
                size_hint: None, 1
                width: root.action_bar_width
                icon_source: root.app_icon_filepath
                title_text: root.action_bar_title

                FullscreenBarButton:
                    id: fullscreen_button
                    on_press: root.toggle_screen_mode()

                BarButton:
                    id: double_page_button
                    text: "Double Page"
                    icon: str(sys_paths.get_barks_reader_double_page_icon_file())
                    important: True
                    on_release: root.toggle_double_page_mode()

                BarButton:
                    id: goto_start_button
                    text: "Goto Start"
                    icon: str(sys_paths.get_barks_reader_goto_start_icon_file())
                    important: True
                    on_release: root.comic_book_reader.goto_start_page()

                BarButton:
                    id: goto_end_button
                    text: "Goto End"
                    icon: str(sys_paths.get_barks_reader_goto_end_icon_file())
                    important: True
                    on_release: root.comic_book_reader.goto_last_page()

                BarButton:
                    id: goto_page_button
                    text: "Goto Page"
                    icon: str(sys_paths.get_barks_reader_goto_icon_file())
                    important: True
                    on_release: root.comic_book_reader.goto_page()

                # Close sits alone in the window corner behind the fence, so an
                # overshoot on the working buttons can't close the comic.
                QuitFence:

                BarButton:
                    id: close_button
                    text: "Close"
                    icon: str(sys_paths.get_barks_reader_close_icon_file())
                    important: True
                    on_release: root.close_comic_book_reader()

        # Image content row — fills remaining space. The inner ComicBookReader is added here
        # from Python and will fit_mode="contain" the comic image inside this area.
        FloatLayout:
            id: image_layout
