<MessagePopup>:
    background_color: (0,0,1,1)
    title: "USER SUPPLIED"
    title_size: fm.message_title_size
    title_font: fm.message_title_font_name
    title_align: "center"
    title_color: (1, 0, 0, 1)
    auto_dismiss: False
    msg_halign: 'justify'
    size_hint: 0.9, 0.5

    FloatLayout:
        # Optional background artwork with a dark scrim so the text stays legible.
        Image:
            source: root.bg_image_source
            opacity: 1 if root.bg_image_source else 0
            fit_mode: "cover"
            mipmap: True
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
        Widget:
            opacity: 1 if root.bg_image_source else 0
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            canvas:
                Color:
                    rgba: 0, 0, 0, 0.45
                Rectangle:
                    pos: self.pos
                    size: self.size

        BoxLayout:
            orientation: "vertical"
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}

            Label:
                text: root.msg_text
                font_size: root.msg_font_scale * fm.error_popup_font_size
                # A very light rounded panel behind the text so the message
                # stands out against the background artwork (quit popup).
                canvas.before:
                    Color:
                        rgba: (0.5, 0.5, 0.5, 0.4) if root.bg_image_source else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.center_x - self.texture_size[0] / 2 - dp(24), self.center_y - self.texture_size[1] / 2 - dp(16)
                        size: self.texture_size[0] + dp(48), self.texture_size[1] + dp(32)
                        radius: [dp(12)]
                multiline: True
                markup: True
                bold: bool(root.bg_image_source)
                outline_color: (0, 0, 0, 1)
                outline_width: dp(1) if root.bg_image_source else 0
                # Constrain the text box to the label's size so long messages
                # (e.g. a big missing-volumes list) wrap instead of overflowing.
                text_size: self.size
                halign: root.msg_halign
                valign: 'middle'
                size_hint: 0.7, 0.9
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}

            BoxLayout:
                orientation: "horizontal"
                size_hint: 0.45, 0.20
                pos_hint: {'right': 1, 'top': 1}
                spacing: dp(10)
                padding: [dp(20),dp(20),dp(20),dp(20)]

                Button:
                    id: ok_button
                    disabled: not root.ok_text
                    opacity: 0 if not root.ok_text else 1
                    text: root.ok_text
                    font_size: fm.error_popup_button_font_size
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    bold: True
                    on_press: root.ok()

                Button:
                    id: cancel_button
                    disabled: not root.cancel_text
                    opacity: 0 if not root.cancel_text else 1
                    size_hint_x: 1 if root.cancel_text else None
                    width: 0
                    text: root.cancel_text
                    font_size: fm.error_popup_button_font_size
                    text_size: self.size
                    halign: 'center'
                    valign: 'middle'
                    on_press: root.cancel()
