#:import Factory kivy.factory.Factory

<ScrollableDropDown@DropDown>:
    scroll_type: ['bars', 'content']
    bar_width: dp(8)
    bar_color: [0.7, 0.7, 0.7, 0.9]
    bar_inactive_color: [0.5, 0.5, 0.5, 0.4]

<ReaderTreeView>:
    hide_root: True
    indent_level: root.TREE_VIEW_INDENT_LEVEL
    size_hint: (1, None)
    minimum_height: self.height

<ButtonTreeViewNode>:
    color: root.TEXT_COLOR
    color_selected: root.SELECTED_COLOR
    background_color: root.BACKGROUND_COLOR
    size_hint: (None, None)
    halign: "left"
    valign: "middle"
    text_size: (self.width, self.height)

<MainTreeViewNode>:
    font_size: fm.tree_view_main_node_font_size
    bold: True
    size: root.NODE_SIZE

<TitleSpinnerOption@SpinnerOption>:
    font_size: fm.tree_view_title_spinner_font_size

<TitleSearchBoxTreeViewNode>:
    size: root.NODE_SIZE
    color_selected: root.SELECTED_COLOR

    BoxLayout:
        orientation: "horizontal"
        size_hint: (1, 1)
        padding: [0, 0, dp(4), 0]
        pos: root.pos

        Label:
            id: title_search_box_label
            text: "Titles: "
            font_size: fm.tree_view_title_search_label_font_size
            color: root.ACTIVE_LABEL_COLOR if root.is_active else root.TEXT_COLOR
            background_color: root.TEXT_BACKGROUND_COLOR
            size_hint: (0.08, 1)
            halign: "right"
            valign: "middle"
            text_size: (self.width, self.height)

        TextInput:
            id: title_search_box
            text: root.text  # Allow the root widget to deal with text
            on_text: root.text = self.text  # Allow 'text' bind on root widget
            font_size: fm.tree_view_title_search_box_font_size
            multiline: False
            foreground_color: root.TEXT_COLOR
            disabled_foreground_color: (1,1,1,0.5)
            background_color: root.TEXT_BACKGROUND_COLOR
            padding: [dp(4), (self.height - self.line_height) / 2]
            size_hint: (0.18, 1)

        Button:
            text: "×"
            bold: True
            font_size: fm.tree_view_title_search_box_font_size
            size_hint: (0.04, 1)
            background_color: (0.35, 0.35, 0.35, 1.0)
            color: (1, 1, 1, 1)
            disabled: not root.text
            on_press: root.clear_and_focus()

        FloatLayout:
            size_hint: (0.70, 1)

            Spinner:
                id: title_spinner
                option_cls: "TitleSpinnerOption"
                dropdown_cls: Factory.ScrollableDropDown
                text: ""
                values: []
                bold: True
                font_size: fm.tree_view_title_spinner_font_size
                color: root.SPINNER_TEXT_COLOR
                background_color: root.SPINNER_BACKGROUND_COLOR
                text_autoupdate: False
                is_open: False
                opacity: 0 if (not self.values and len(root.text) > 1) else 1
                disabled: not self.values and len(root.text) > 1
                size_hint: (1, 1)
                pos_hint: {'x': 0, 'y': 0}
                halign: "center"
                valign: "middle"
                text_size: (self.width, self.height)

            Label:
                text: "no matches"
                italic: True
                opacity: 0.6 if (not root.ids.title_spinner.values and len(root.text) > 1) else 0
                color: root.SPINNER_TEXT_COLOR
                size_hint: (1, 1)
                pos_hint: {'x': 0, 'y': 0}
                halign: "center"
                valign: "middle"
                text_size: (self.width, self.height)

<TagSpinnerOption@SpinnerOption>:
    font_size: fm.tree_view_tag_spinner_font_size

<TagTitleSpinnerOption@SpinnerOption>:
    font_size: fm.tree_view_tag_title_spinner_font_size

<TagSearchBoxTreeViewNode>:
    size: root.NODE_SIZE
    color_selected: root.SELECTED_COLOR

    BoxLayout:
        orientation: "vertical"
        size_hint: (1, 1)
        pos: root.pos

        BoxLayout:
            orientation: "horizontal"
            size_hint: (1, 0.5)
            padding: [0, 0, dp(4), 0]

            Label:
                id: tag_search_label
                text: "Tags: "
                font_size: fm.tree_view_tag_search_label_font_size
                color: root.ACTIVE_LABEL_COLOR if root.is_active else root.TAG_LABEL_COLOR
                background_color: root.TAG_LABEL_BACKGROUND_COLOR
                size_hint: (0.08, 1)
                halign: "right"
                valign: "middle"
                text_size: (self.width, self.height)

            TextInput:
                id: tag_search_box
                text: root.text
                on_text: root.text = self.text
                font_size: fm.tree_view_tag_search_box_font_size
                multiline: False
                foreground_color: root.TAG_TEXT_COLOR
                disabled_foreground_color: (1,1,1,0.5)
                background_color: root.TAG_TEXT_BACKGROUND_COLOR
                padding: [dp(4), (self.height - self.line_height) / 2]
                size_hint: (0.18, 1)

            Button:
                text: "×"
                bold: True
                font_size: fm.tree_view_tag_search_box_font_size
                size_hint: (0.04, 1)
                background_color: (0.35, 0.35, 0.35, 1.0)
                color: (1, 1, 1, 1)
                disabled: not root.text
                on_press: root.clear_and_focus()

            FloatLayout:
                size_hint: (0.70, 1)

                Spinner:
                    id: tag_spinner
                    option_cls: "TagSpinnerOption"
                    dropdown_cls: Factory.ScrollableDropDown
                    text: ""
                    values: []
                    markup: True
                    font_size: fm.tree_view_tag_spinner_font_size
                    color: root.TAG_SPINNER_TEXT_COLOR
                    background_color: root.TAG_SPINNER_BACKGROUND_COLOR
                    text_autoupdate: False
                    is_open: False
                    opacity: 0 if (not self.values and len(root.text) > 1) else 1
                    disabled: not self.values and len(root.text) > 1
                    size_hint: (1, 1)
                    pos_hint: {'x': 0, 'y': 0}
                    halign: "center"
                    valign: "middle"
                    text_size: (self.width, self.height)

                Label:
                    text: "no matches"
                    italic: True
                    opacity: 0.6 if (not root.ids.tag_spinner.values and len(root.text) > 1) else 0
                    color: root.TAG_SPINNER_TEXT_COLOR
                    size_hint: (1, 1)
                    pos_hint: {'x': 0, 'y': 0}
                    halign: "center"
                    valign: "middle"
                    text_size: (self.width, self.height)

        BoxLayout:
            orientation: "horizontal"
            size_hint: (1, 0.5)
            padding: [0, 0, dp(4), 0]

            Label:
                text: "Title: "
                font_size: fm.tree_view_tag_search_label_font_size
                color: root.TAG_LABEL_COLOR
                background_color: root.TAG_LABEL_BACKGROUND_COLOR
                size_hint: (0.08, 1)
                halign: "left"
                valign: "middle"
                text_size: (self.width, self.height)

            Widget:
                size_hint: (0.22, 1)

            Spinner:
                id: tag_title_spinner
                option_cls: "TagTitleSpinnerOption"
                dropdown_cls: Factory.ScrollableDropDown
                text: ""
                values: []
                bold: False
                markup: True
                font_size: fm.tree_view_tag_title_spinner_font_size
                color: root.TAG_TITLE_SPINNER_TEXT_COLOR
                background_color: root.TAG_TITLE_SPINNER_BACKGROUND_COLOR
                text_autoupdate: False
                is_open: False
                size_hint: (0.70, 1)
                halign: "center"
                valign: "middle"
                text_size: (self.width, self.height)

<StoryGroupTreeViewNode>:
    font_size: fm.tree_view_story_node_font_size
    markup: True
    height: root.NODE_HEIGHT
    width: root.NODE_WIDTH

<YearRangeTreeViewNode>:
    font_size: fm.tree_view_year_range_node_font_size
    markup: True
    height: root.NODE_HEIGHT
    width: root.NODE_WIDTH

<TreeViewRowNode@BoxLayout>:
    orientation: "horizontal"
    spacing: 0

<TitleTreeViewNode>:
    orientation: "vertical"
    color: root.TEXT_COLOR
    color_selected: root.SELECTED_COLOR
    background_color: root.BACKGROUND_COLOR
    even_color:  self.EVEN_COLOR
    odd_color:  self.ODD_COLOR
    spacing: 0
    size_hint_y: None
    height: dp(2 * self.ROW_HEIGHT)
    minimum_height: self.height
    minimum_width: self.width

    TreeViewRowNode:
        TreeViewButton:
            id: num_label
            parent: root
            font_size: fm.tree_view_num_label_font_size
            color: root.NUM_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            color_selected: (1,0,1,1)
            bg_color: (1,1,0,0.5)
            bold: True
            size_hint: (None, None)
            width: root.NUM_LABEL_WIDTH
            height: root.ROW_HEIGHT
            halign: "right"
            valign: "middle"
            text_size: (self.width, self.height)

        TitleTreeViewLabel:
            text: ""
            parent: root
            font_size: fm.tree_view_num_label_font_size
            color: root.NUM_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            size_hint: (None, None)
            width: dp(10)
            height: root.ROW_HEIGHT
            halign: "right"
            valign: "middle"
            text_size: (self.width, self.height)

        TitleTreeViewLabel:
            id: title_label
            parent: root
            font_size: fm.tree_view_title_label_font_size
            color: root.TITLE_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            bold: True
            mipmap: True
            size_hint: (None, None)
            width: root.TITLE_LABEL_WIDTH
            height: root.ROW_HEIGHT
            halign: "left"
            valign: "middle"
            text_size: (self.width, self.height)

    TreeViewRowNode:
        TitleTreeViewLabel:
            text: "   "
            parent: root
            color: root.NUM_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            size_hint: (None, None)
            width: root.NUM_LABEL_WIDTH
            height: root.ROW_HEIGHT
            halign: "right"
            valign: "middle"
            text_size: (self.width, self.height)

        TitleTreeViewLabel:
            text: ""
            parent: root
            color: root.NUM_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            size_hint: (None, None)
            width: dp(10)
            height: root.ROW_HEIGHT
            halign: "right"
            valign: "middle"
            text_size: (self.width, self.height)

        TitleTreeViewLabel:
            id: issue_label
            parent: root
            font_size: fm.tree_view_issue_label_font_size
            color: root.ISSUE_LABEL_COLOR
            background_color: root.ROW_BACKGROUND_COLOR
            markup: True
            mipmap: True
            size_hint: (None, None)
            width: root.ISSUE_LABEL_WIDTH
            height: root.ROW_HEIGHT
            halign: "left"
            valign: "middle"
            text_size: (self.width, self.height)
