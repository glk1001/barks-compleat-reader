<_SearchResultButton>:
    background_normal: ''
    background_down: ''
    background_color: (0.15, 0.15, 0.15, 1) if self.state == 'normal' else (0.0, 0.4, 0.0, 1)
    color: (1, 1, 0, 1)
    size_hint_y: None
    height: dp(28)
    halign: 'left'
    valign: 'middle'
    text_size: self.width, self.height
    font_size: dp(12)
    padding: [dp(8), 0]

<_TagChipButton>:
    size_hint: None, None
    height: dp(26)
    font_size: dp(11)
    background_normal: ''
    background_down: ''
    background_color: (0, 0, 0, 0)
    color: (0.8, 1, 0.8, 1)
    canvas.before:
        Color:
            rgba: self.chip_bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<SearchScreen>:
    opacity: 1 if root.is_visible else 0
    size_hint: (1, 1) if root.is_visible else (0, 0)

    canvas.before:
        Color:
            rgba: 0.08, 0.08, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

        # ---- Title Search Content ----
        BoxLayout:
            id: title_search_content
            orientation: 'horizontal'
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            padding: dp(8)
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.25
                spacing: dp(4)

                Label:
                    text: "Title:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: dp(12)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: title_search_input
                        multiline: False
                        font_size: dp(12)
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text: root.on_title_search_text(self.text)

                    Button:
                        text: "\u00d7"
                        bold: True
                        font_size: dp(14)
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_title_clear()

                Widget:

            ScrollView:
                size_hint_x: 0.75
                always_overscroll: False
                effect_cls: 'ScrollEffect'
                scroll_type: ['bars', 'content']
                bar_color: (0.7, 0.7, 0.7, 0.9)
                bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                bar_width: dp(8)

                BoxLayout:
                    id: title_results_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(1)

        # ---- Tag Search Content ----
        BoxLayout:
            id: tag_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'x': 0, 'y': 0}
            padding: dp(8)
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.25
                spacing: dp(4)

                Label:
                    text: "Tag:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: dp(12)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: tag_search_input
                        multiline: False
                        font_size: dp(12)
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text: root.on_tag_search_text(self.text)

                    Button:
                        text: "\u00d7"
                        bold: True
                        font_size: dp(14)
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_tag_clear()

                ScrollView:
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    StackLayout:
                        id: tag_chips_layout
                        orientation: 'lr-tb'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)
                        padding: dp(2)

            ScrollView:
                size_hint_x: 0.75
                always_overscroll: False
                effect_cls: 'ScrollEffect'
                scroll_type: ['bars', 'content']
                bar_color: (0.7, 0.7, 0.7, 0.9)
                bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                bar_width: dp(8)

                BoxLayout:
                    id: tag_title_results_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(1)

        # ---- Word Search Content ----
        BoxLayout:
            id: word_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'x': 0, 'y': 0}
            padding: dp(8)
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.25
                spacing: dp(4)

                Label:
                    text: "Words:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: dp(12)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: word_search_input
                        multiline: False
                        font_size: dp(12)
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text_validate: root.on_word_search_submit()

                    Button:
                        text: "\u00d7"
                        bold: True
                        font_size: dp(14)
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_word_clear()

                Button:
                    text: "Search"
                    bold: True
                    font_size: dp(12)
                    size_hint_y: None
                    height: dp(30)
                    background_color: (0.0, 0.4, 0.0, 1.0)
                    on_press: root.on_word_search_submit()

                Widget:

            ScrollView:
                size_hint_x: 0.75
                always_overscroll: False
                effect_cls: 'ScrollEffect'
                scroll_type: ['bars', 'content']
                bar_color: (0.7, 0.7, 0.7, 0.9)
                bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                bar_width: dp(8)

                BoxLayout:
                    id: word_results_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(1)
