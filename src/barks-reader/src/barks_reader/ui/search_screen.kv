#:import reader_palette barks_reader.core.reader_palette

<_SearchResultButton>:
    background_normal: ''
    background_down: ''
    border: [0, 0, 0, 0]
    background_color:
        reader_palette.theme().accent_selection \
        if (self.selected or self.state != 'normal') \
        else (reader_palette.theme().row_stripe_even if self.row_index % 2 == 0 \
        else reader_palette.theme().row_stripe_odd)
    color: reader_palette.theme().text_title
    size_hint_y: None
    height: dp(28)
    halign: 'left'
    valign: 'middle'
    text_size: self.width, self.height
    font_size: fm.search_result_font_size
    padding: [dp(8), 0]

<_TagChipButton>:
    size_hint: 1, None
    height: dp(26)
    font_size: fm.search_tag_chip_font_size
    background_normal: ''
    background_down: ''
    background_color: (0, 0, 0, 0)
    color: reader_palette.theme().text_secondary
    canvas.before:
        Color:
            rgba: self.chip_bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    canvas.after:
        Color:
            rgba: self.chip_border_color
        SmoothLine:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(12))
            width: dp(1.5)

<SearchInput@TouchAwareTextInput>:
    multiline: False
    # Enter must not blur the input when there is nothing to focus; the
    # on_text_validate handler blurs explicitly when it does move focus.
    text_validate_unfocus: False
    font_size: fm.search_input_font_size
    foreground_color: (1, 1, 1, 1)
    hint_text_color: (1, 1, 1, 0.4)
    background_color: (0.08, 0.08, 0.08, 0.82)
    cursor_color: reader_palette.theme().focus_ring
    cursor_width: dp(2)
    padding: [dp(12), (self.height - self.line_height) / 2]

<SearchClearButton@Button>:
    text: "×"
    bold: True
    font_size: fm.search_clear_button_font_size
    size_hint_x: None
    width: dp(44)
    background_normal: ''
    background_down: ''
    background_color: (0.18, 0.18, 0.18, 0.9)

<SearchScroll@ScrollView>:
    always_overscroll: False
    effect_cls: 'ScrollEffect'
    scroll_type: ['bars', 'content']
    bar_color: (0.7, 0.7, 0.7, 0.9)
    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
    bar_width: dp(8)

# A translucent rounded panel that frames a list area, so the screen layout
# reads as designed even before any search results exist.
<SearchPanel@FloatLayout>:
    canvas.before:
        Color:
            rgba: 0.04, 0.04, 0.04, 0.6
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]

<SearchEmptyPrompt@Label>:
    italic: True
    font_size: fm.search_label_font_size
    color: reader_palette.theme().text_secondary
    halign: 'center'
    valign: 'middle'
    text_size: self.width - dp(40), None
    size_hint: 1, 1
    pos_hint: {'x': 0, 'y': 0}

<SearchScreen>:
    opacity: 1 if root.is_visible else 0
    size_hint: (1, 1) if root.is_visible else (0, 0)

    canvas.before:
        Color:
            rgba: 0.08, 0.08, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

        Image:
            texture: root.image_texture
            fit_mode: "cover"
            opacity: 0.35
            mipmap: True

        GotoTitleOverlay:
            current_title_str: root.current_title_str
            show_title: root.show_current_title
            on_arrow_press: root.on_goto_background_title()

        # ---- Title Search Content ----
        BoxLayout:
            id: title_search_content
            orientation: 'horizontal'
            size_hint: 0.86, 1
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(12)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(8)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(2)

                    SearchInput:
                        id: title_search_input
                        hint_text: "Search titles…"
                        on_text: root.on_title_search_text(self.text)
                        on_text_validate: root.on_search_input_enter()

                    SearchClearButton:
                        id: title_clear_button
                        on_release: root.on_title_clear()

                Widget:

            SearchPanel:
                size_hint_x: 0.65

                BoxLayout:
                    size_hint: 1, 1
                    pos_hint: {'x': 0, 'y': 0}
                    padding: dp(8)

                    SearchScroll:
                        id: title_results_scroll

                        BoxLayout:
                            id: title_results_layout
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(1)

                SearchEmptyPrompt:
                    text: "Matching story titles will appear here"
                    opacity: 0 if title_results_layout.children else 0.75

        # ---- Tag Search Content ----
        BoxLayout:
            id: tag_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(12)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(8)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(2)

                    SearchInput:
                        id: tag_search_input
                        hint_text: "Search tags…"
                        on_text: root.on_tag_search_text(self.text)
                        on_text_validate: root.on_search_input_enter()

                    SearchClearButton:
                        id: tag_clear_button
                        on_release: root.on_tag_clear()

                SearchPanel:

                    BoxLayout:
                        size_hint: 1, 1
                        pos_hint: {'x': 0, 'y': 0}
                        padding: dp(8)

                        SearchScroll:

                            BoxLayout:
                                id: tag_chips_layout
                                orientation: 'vertical'
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(4)

                    SearchEmptyPrompt:
                        text: "Matching tags will appear here"
                        opacity: 0 if tag_chips_layout.children else 0.75

            SearchPanel:
                size_hint_x: 0.65

                BoxLayout:
                    size_hint: 1, 1
                    pos_hint: {'x': 0, 'y': 0}
                    padding: dp(8)

                    SearchScroll:
                        id: tag_results_scroll

                        BoxLayout:
                            id: tag_title_results_layout
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(1)

                SearchEmptyPrompt:
                    text: "Pick a tag to list its stories"
                    opacity: 0 if tag_title_results_layout.children else 0.75

        # ---- Word Search Content ----
        BoxLayout:
            id: word_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(12)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(8)

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(2)

                    SearchInput:
                        id: word_search_input
                        hint_text: "Search words…"
                        on_text: root.on_word_search_text(self.text)
                        on_text_validate: root.on_search_input_enter()

                    SearchClearButton:
                        id: word_clear_button
                        on_release: root.on_word_clear()

                SearchPanel:

                    BoxLayout:
                        size_hint: 1, 1
                        pos_hint: {'x': 0, 'y': 0}
                        padding: dp(8)

                        SearchScroll:
                            id: word_chips_scroll

                            BoxLayout:
                                id: word_chips_layout
                                orientation: 'vertical'
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(1)

                    SearchEmptyPrompt:
                        text: "Matching words will appear here"
                        opacity: 0 if word_chips_layout.children else 0.75

            SearchPanel:
                size_hint_x: 0.65

                BoxLayout:
                    size_hint: 1, 1
                    pos_hint: {'x': 0, 'y': 0}
                    padding: dp(8)

                    SearchScroll:
                        id: word_results_scroll

                        BoxLayout:
                            id: word_results_layout
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(1)

                SearchEmptyPrompt:
                    text: "Pick a word to see where it is spoken"
                    opacity: 0 if word_results_layout.children else 0.75
