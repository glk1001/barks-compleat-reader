<_SearchResultButton>:
    background_normal: ''
    background_down: ''
    border: [0, 0, 0, 0]
    background_color: ((0.15, 0.15, 0.15, 0.4) if self.row_index % 2 == 0 else (0.22, 0.22, 0.22, 0.4)) if self.state == 'normal' else (0.0, 0.4, 0.0, 0.55)
    color: (1, 1, 0, 1)
    size_hint_y: None
    height: dp(28)
    halign: 'left'
    valign: 'middle'
    text_size: self.width, self.height
    font_size: fm.search_result_font_size
    padding: [dp(8), 0]

<_TagChipButton>:
    size_hint: None, None
    height: dp(26)
    font_size: fm.search_tag_chip_font_size
    background_normal: ''
    background_down: ''
    background_color: (0, 0, 0, 0)
    color: (0.8, 1, 0.8, 1)
    canvas.before:
        Color:
            rgba: self.chip_bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    canvas.after:
        Color:
            rgba: self.chip_border_color
        SmoothLine:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(12))
            width: dp(1.5)

<SearchScreen>:
    opacity: 1 if root.is_visible else 0
    size_hint: (1, 1) if root.is_visible else (0, 0)

    canvas.before:
        Color:
            rgba: 0.08, 0.08, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

        Image:
            texture: root.image_texture
            fit_mode: "cover"
            opacity: 0.35
            mipmap: True

        GotoTitleOverlay:
            current_title_str: root.current_title_str
            show_title: root.show_current_title
            on_arrow_press: root.on_goto_background_title()

        # ---- Title Search Content ----
        BoxLayout:
            id: title_search_content
            orientation: 'horizontal'
            size_hint: 0.86, 1
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(4)

                Label:
                    text: "Title:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: title_search_input
                        multiline: False
                        font_size: fm.search_input_font_size
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text: root.on_title_search_text(self.text)

                    Button:
                        id: title_clear_button
                        text: "\u00d7"
                        bold: True
                        font_size: fm.search_clear_button_font_size
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_title_clear()

                Widget:

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.65
                spacing: dp(4)

                Label:
                    text: "Titles"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                ScrollView:
                    id: title_results_scroll
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    BoxLayout:
                        id: title_results_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

        # ---- Tag Search Content ----
        BoxLayout:
            id: tag_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(4)

                Label:
                    text: "Tag:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: tag_search_input
                        multiline: False
                        font_size: fm.search_input_font_size
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text: root.on_tag_search_text(self.text)

                    Button:
                        id: tag_clear_button
                        text: "\u00d7"
                        bold: True
                        font_size: fm.search_clear_button_font_size
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_tag_clear()

                ScrollView:
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    BoxLayout:
                        id: tag_chips_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.65
                spacing: dp(4)

                Label:
                    text: "Titles"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                ScrollView:
                    id: tag_results_scroll
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    BoxLayout:
                        id: tag_title_results_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

        # ---- Word Search Content ----
        BoxLayout:
            id: word_search_content
            orientation: 'horizontal'
            size_hint: 0, 0
            opacity: 0
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: [dp(40), dp(30), dp(40), dp(35)]
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.35
                spacing: dp(4)

                Label:
                    text: "Words:"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(2)

                    TextInput:
                        id: word_search_input
                        multiline: False
                        font_size: fm.search_input_font_size
                        foreground_color: (1, 1, 1, 1)
                        background_color: (0.3, 0.3, 0.3, 0.8)
                        padding: [dp(4), (self.height - self.line_height) / 2]
                        on_text: root.on_word_search_text(self.text)

                    Button:
                        id: word_clear_button
                        text: "\u00d7"
                        bold: True
                        font_size: fm.search_clear_button_font_size
                        size_hint_x: None
                        width: dp(30)
                        background_color: (0.35, 0.35, 0.35, 1.0)
                        on_release: root.on_word_clear()

                ScrollView:
                    id: word_chips_scroll
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    BoxLayout:
                        id: word_chips_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.65
                spacing: dp(4)

                Label:
                    text: "Titles"
                    size_hint_y: None
                    height: dp(24)
                    color: (0.5, 1, 0.5, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    font_size: fm.search_label_font_size

                ScrollView:
                    id: word_results_scroll
                    always_overscroll: False
                    effect_cls: 'ScrollEffect'
                    scroll_type: ['bars', 'content']
                    bar_color: (0.7, 0.7, 0.7, 0.9)
                    bar_inactive_color: (0.5, 0.5, 0.5, 0.4)
                    bar_width: dp(8)

                    BoxLayout:
                        id: word_results_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)
