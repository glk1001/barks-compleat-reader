[importlinter]
root_packages =
    barks_reader
    barks_fantagraphics
    comic_utils
    okf_reader
include_external_packages=True

[importlinter:contract:1]
name = Core should remain pure and never import UI
type = forbidden
source_modules =
    barks_reader.core
forbidden_modules =
    barks_reader.ui
    kivy

[importlinter:contract:2]
name = barks_fantagraphics must not import barks_reader
type = forbidden
source_modules =
    barks_fantagraphics
forbidden_modules =
    barks_reader

[importlinter:contract:3]
name = comic_utils must not import barks_reader or barks_fantagraphics
type = forbidden
source_modules =
    comic_utils
forbidden_modules =
    barks_reader
    barks_fantagraphics

[importlinter:contract:4]
name = Low-level packages must not import kivy
type = forbidden
source_modules =
    barks_fantagraphics
    comic_utils
forbidden_modules =
    kivy

[importlinter:contract:5]
name = okf_reader core should remain pure and never import UI or kivy
type = forbidden
source_modules =
    okf_reader.core
forbidden_modules =
    okf_reader.ui
    kivy

[importlinter:contract:6]
name = okf_reader must stay independent of the Barks packages
type = forbidden
source_modules =
    okf_reader
forbidden_modules =
    barks_reader
    barks_fantagraphics

